# ═══════════════════════════════════════════════════════════
# EcoSentinel — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ─── Required ─────────────────────────────────────────────
# Google Gemini API Key (free from https://aistudio.google.com/)
# Used by the Explanation Agent for AI briefings and chat
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional ─────────────────────────────────────────────
# Telegram Bot (for remote alert delivery)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# NASA API Key (DEMO_KEY works for basic usage)
NASA_API_KEY=DEMO_KEY

# ─── Database ─────────────────────────────────────────────
# Leave commented for local SQLite (recommended for local dev)
# Uncomment and set for PostgreSQL in production
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
